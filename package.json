{
  "name": "my-app",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @my-app/web dev",
    "dev:api": "pnpm --filter @my-app/api dev",
    "build:web": "pnpm --filter @my-app/web build",
    "build:api": "pnpm --filter @my-app/api build"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
